<Window x:Class="vizprog_eloadas_beadando_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:vizprog_eloadas_beadando_app"
        mc:Ignorable="d"
        Title="Napló"
        Height="720"
        Width="1240"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Window.Resources>

        <SolidColorBrush x:Key="AppBg" Color="#0F172A"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#111827"/>
        <SolidColorBrush x:Key="CardBg" Color="#1E293B"/>
        <SolidColorBrush x:Key="CardBgHover" Color="#263449"/>
        <SolidColorBrush x:Key="BorderColor" Color="#334155"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#38BDF8"/>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#A78BFA"/>
        <SolidColorBrush x:Key="SuccessBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="TextMain" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="InputBg" Color="#0F172A"/>
        <SolidColorBrush x:Key="SelectedRowBg" Color="#1E40AF"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="3"
                                      Opacity="0.22"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#1F2937"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.03"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.03"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource SuccessBlue}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.90"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.04"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.04"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="3"
                                      Opacity="0.22"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="card"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="card" Property="Background" Value="{StaticResource CardBgHover}"/>
                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="card" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.055"
                                             Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.055"
                                             Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,0,14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBlue}"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,0,14"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,6,0,16"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1E293B"/>
            <Setter Property="AlternatingRowBackground" Value="#172033"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="#334155"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#263449"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SelectedRowBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource AppBg}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="245"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,1,0">

            <DockPanel>

                <StackPanel DockPanel.Dock="Top"
                            Margin="20,24,20,20">

                    <TextBlock Text="▧  Napló"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMain}"/>
                </StackPanel>

                <StackPanel>
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Click="VisszaFoMenu_click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌂" FontSize="19" Margin="0,0,12,0"/>
                            <TextBlock Text="Főoldal" FontSize="15"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Click="Adatok_diakok_click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♟" FontSize="19" Margin="0,0,12,0"/>
                            <TextBlock Text="Diákok" FontSize="15"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Click="Adatok_jegyek_click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▤" FontSize="19" Margin="0,0,12,0"/>
                            <TextBlock Text="Jegyek" FontSize="15"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Click="Adatok_targyak_click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▥" FontSize="19" Margin="0,0,12,0"/>
                            <TextBlock Text="Tárgyak" FontSize="15"/>
                        </StackPanel>
                    </Button>

                    <Separator Margin="18,14"
                               Background="{StaticResource BorderColor}"/>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Click="Fajl_bezaras_click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▣" FontSize="19" Margin="0,0,12,0"/>
                            <TextBlock Text="Kilépés" FontSize="15"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#111827"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Padding="22,12">

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Napló kezelő rendszer"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Diákok, jegyek és tárgyak kezelése"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Style="{StaticResource ActionButtonStyle}"
                                Background="{StaticResource SuccessBlue}"
                                Click="Hozzaadas_click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" Foreground="White" FontWeight="Bold" Margin="0,0,7,0"/>
                                <TextBlock Text="Hozzáadás" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ActionButtonStyle}"
                                Background="{StaticResource WarningOrange}"
                                Click="Modositas_click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✎" Foreground="White" FontWeight="Bold" Margin="0,0,7,0"/>
                                <TextBlock Text="Módosítás" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ActionButtonStyle}"
                                Background="{StaticResource DangerRed}"
                                Click="Torles_click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌫" Foreground="White" FontWeight="Bold" Margin="0,0,7,0"/>
                                <TextBlock Text="Törlés" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ActionButtonStyle}"
                                Background="{StaticResource PrimaryPurple}"
                                Click="Frissites_click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻" Foreground="White" FontWeight="Bold" Margin="0,0,7,0"/>
                                <TextBlock Text="Frissítés" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1"
                  Margin="26">

                <Grid x:Name="foMenuGrid">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,0,26">

                        <StackPanel>
                            <TextBlock Text="Üdv a Napló rendszerben"
                                       FontSize="32"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Válassz egy modult bal oldalt vagy az alábbi kártyák közül."
                                       FontSize="15"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource DashboardCardButtonStyle}"
                                Height="255"
                                Click="Adatok_diakok_click">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="♟"
                                           FontSize="46"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="Diákok"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Tanulók adatainak kezelése"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource TextMuted}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                Style="{StaticResource DashboardCardButtonStyle}"
                                Height="255"
                                Click="Adatok_jegyek_click">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="▤"
                                           FontSize="46"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="Jegyek"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Értékelések rögzítése"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource TextMuted}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource DashboardCardButtonStyle}"
                                Height="255"
                                Click="Adatok_targyak_click">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="▥"
                                           FontSize="46"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="Tárgyak"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Tantárgyak kezelése"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource TextMuted}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <Grid x:Name="adatOldalGrid"
                      Visibility="Collapsed">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,18">

                        <Button Width="190"
                                Height="40"
                                DockPanel.Dock="Left"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#334155"
                                Click="VisszaFoMenu_click">

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="←" Foreground="White" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Text="Vissza a főoldalra" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <TextBlock x:Name="oldalCimTextBlock"
                                   Text="Adatok"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="18,0,0,0"/>
                    </DockPanel>

                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="330"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource CardBorderStyle}">

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Background="Transparent">

                                <StackPanel x:Name="inputPanel"
                                            Visibility="Collapsed">

                                    <StackPanel x:Name="diakInput"
                                                Visibility="Collapsed">

                                        <TextBlock Text="Diák adatai"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,20"/>

                                        <TextBlock Text="Név:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="diakNevTextBox"/>

                                        <TextBlock Text="Osztály:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="diakOsztalyTextBox"/>

                                        <TextBlock Text="Fiú:" FontWeight="SemiBold"/>
                                        <CheckBox x:Name="diakFiuCheckBox"
                                                  Content="Igen"/>
                                    </StackPanel>

                                    <StackPanel x:Name="jegyInput"
                                                Visibility="Collapsed">

                                        <TextBlock Text="Jegy adatai"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,20"/>

                                        <TextBlock Text="Diák ID:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="jegyDiakIdTextBox"/>

                                        <TextBlock Text="Dátum:" FontWeight="SemiBold"/>
                                        <DatePicker x:Name="jegyDatumDatePicker"/>

                                        <TextBlock Text="Érték:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="jegyErtekTextBox"/>

                                        <TextBlock Text="Típus:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="jegyTipusTextBox"/>

                                        <TextBlock Text="Tárgy ID:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="jegyTargyIdTextBox"/>
                                    </StackPanel>

                                    <StackPanel x:Name="targyInput"
                                                Visibility="Collapsed">

                                        <TextBlock Text="Tárgy adatai"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,20"/>

                                        <TextBlock Text="Név:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="targyNevTextBox"/>

                                        <TextBlock Text="Kategória:" FontWeight="SemiBold"/>
                                        <TextBox x:Name="targyKategoriaTextBox"/>
                                    </StackPanel>

                                    <Separator Margin="0,10,0,14"
                                               Background="{StaticResource BorderColor}"/>

                                    <Button Height="40"
                                            Margin="0,6,0,6"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Background="{StaticResource SuccessBlue}"
                                            Click="Hozzaadas_click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="+" Foreground="White" FontWeight="Bold" Margin="0,0,7,0"/>
                                            <TextBlock Text="Hozzáadás" Foreground="White"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Height="40"
                                            Margin="0,6,0,6"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Background="{StaticResource WarningOrange}"
                                            Click="Modositas_click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✎" Foreground="White" FontWeight="Bold" Margin="0,0,7,0"/>
                                            <TextBlock Text="Módosítás" Foreground="White"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Height="40"
                                            Margin="0,6,0,6"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Background="{StaticResource DangerRed}"
                                            Click="Torles_click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⌫" Foreground="White" FontWeight="Bold" Margin="0,0,7,0"/>
                                            <TextBlock Text="Törlés" Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="1"
                                SnapsToDevicePixels="True">

                            <Grid ClipToBounds="True">
                                <DataGrid x:Name="myDataGrid"
                                          AutoGenerateColumns="True"
                                          SelectionMode="Single"
                                          IsReadOnly="True"
                                          SelectionChanged="myDataGrid_SelectionChanged"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          RowHeaderWidth="0"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          Margin="0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
    