<Window x:Class="vizprog_eloadas_beadando_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:vizprog_eloadas_beadando_app"
        mc:Ignorable="d"
        Title="Napló" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Fájl">
                <MenuItem Header="Bezárás" Click="Fajl_bezaras_click"/>
            </MenuItem>
            <MenuItem Header="Diákok" Click="Adatok_diakok_click"/>
            <MenuItem Header="Jegyek" Click="Adatok_jegyek_click"/>
            <MenuItem Header="Tárgyak" Click="Adatok_targyak_click"/>
        </Menu>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Hozzáadás" Click="Hozzaadas_click"/>
                <Button Content="Módosítás" Click="Modositas_click"/>
                <Button Content="Törlés" Click="Torles_click"/>
                <Button Content="Frissítés" Click="Frissites_click"/>
            </ToolBar>
        </ToolBarTray>
        <Grid>
            <DataGrid x:Name="myDataGrid" AutoGenerateColumns="True" SelectionMode="Single"/>
        </Grid>
    </DockPanel>
</Window>
